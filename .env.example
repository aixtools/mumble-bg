# Read-only pilot source connection
PILOT_DATABASE_NAME=pilot_db
PILOT_DATABASE_HOST=127.0.0.1
PILOT_DATABASE_USER=pilot_user
PILOT_DATABASE_PASSWORD=change_me

# mumble-bg owned runtime database
MMBL_BG_DATABASE_NAME=MMBL_BG
MMBL_BG_DATABASE_HOST=127.0.0.1
MMBL_BG_DATABASE_USER=mumble_bg
MMBL_BG_DATABASE_PASSWORD=change_me

# Optional provisioning-only engine for deploy/create-db.sh and setup-hetzner.sh.
# Defaults to postgres when omitted.
# BG_ENGINE=psql
