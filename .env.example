# Read-only Cube-core connection
CUBE_CORE_DATABASE_NAME=cube_db
CUBE_CORE_DATABASE_HOST=127.0.0.1
CUBE_CORE_DATABASE_USER=cube_user
CUBE_CORE_DATABASE_PASSWORD=change_me
CUBE_CORE_DATABASE_ENGINE=postgresql

# mumble-bg owned runtime database
MMBL_BG_DATABASE_NAME=MMBL_BG
MMBL_BG_DATABASE_HOST=127.0.0.1
MMBL_BG_DATABASE_USER=mumble_bg
MMBL_BG_DATABASE_PASSWORD=change_me
MUMBLE_ICE_SLICE=/home/cube/mumble-bg/bg/authd/MumbleServer.ice
